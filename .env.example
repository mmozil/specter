# ── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://murdock:murdock@localhost:5432/murdock

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/5

# ── LLM (SEED inicial — depois é configurável pela UI /Configurações → LLM) ──
# Estas envs só populam o banco no 1º boot (tabela llm_providers vazia). A partir daí,
# o usuário escolhe modelo/ordem/on-off pela UI (persistido em DB, sem redeploy).
DEFAULT_LLM_PROVIDER=minimax
DEFAULT_LLM_MODEL=MiniMax-M2
DEFAULT_LLM_BASE_URL=https://api.minimax.io/v1
DEFAULT_LLM_API_KEY=

# Fallback do seed (vira o 2º provedor, priority 20)
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Auth ──────────────────────────────────────
SECRET_KEY=change-me-in-production
API_KEY=murdock-api-key-change-me
# Opcional: chave Fernet dedicada p/ criptografar as API keys de LLM no banco.
# Se ausente, é derivada do SECRET_KEY (estável enquanto o SECRET_KEY não mudar).
MURDOCK_ENCRYPTION_KEY=

# ── Server ────────────────────────────────────
ENVIRONMENT=development
PORT=8010
